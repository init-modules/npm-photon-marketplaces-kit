{
	"compilerOptions": {
		"target": "ES2022",
		"lib": ["DOM", "ES2022"],
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"jsx": "react-jsx",
		"baseUrl": ".",
		"paths": {
			"@init/photon": ["../../photon-foundation/photon/src/index.ts"],
			"@init/photon/public": ["../../photon-foundation/photon/src/public.tsx"],
			"@init/photon/server": ["../../photon-foundation/photon/src/server.ts"],
			"@init/photon/shared": ["../../photon-foundation/photon/src/shared.ts"],
			"@init/photon-base-kit": ["../../photon-foundation/photon-base-kit/src/index.ts"],
			"@init/photon-base-kit/public": [
				"../../photon-foundation/photon-base-kit/src/public.tsx"
			],
			"@init/commerce": ["../../commerce-foundation/commerce/src/index.ts"],
			"@init/commerce/client": [
				"../../commerce-foundation/commerce/src/client.ts"
			],
			"@init/commerce-photon": [
				"../../commerce-foundation/commerce-photon/src/index.ts"
			],
			"@init/commerce-photon/public": [
				"../../commerce-foundation/commerce-photon/src/public.tsx"
			],
			"@init/commerce-profile-templates": [
				"../../commerce-foundation/commerce-profile-templates/src/index.ts"
			],
			"@init/auth-photon": [
				"../../auth-foundation/auth-photon/src/index.ts"
			],
			"@init/ui": ["../../ui-foundation/ui/src/index.ts"]
		},
		"strict": true,
		"skipLibCheck": true,
		"noEmit": true,
		"esModuleInterop": true,
		"resolveJsonModule": true
	},
	"include": ["src/**/*"]
}
